###############################################################################
#
# Monitoring-Grafana Project
#
# File:
#   .env.example
#
# Description:
#   Example environment configuration for the Monitoring-Grafana stack.
#
###############################################################################

###############################################################################
# General
###############################################################################

TZ=Europe/Prague

###############################################################################
# Docker Compose
###############################################################################

COMPOSE_PROJECT_NAME=monitoring-grafana

###############################################################################
# Traefik
###############################################################################

TRAEFIK_VERSION=v3.6.16

# Public e-mail used for Let's Encrypt
TRAEFIK_ACME_EMAIL=admin@example.com

# Public dashboard hostname
TRAEFIK_DOMAIN=traefik.example.com

###############################################################################
# CrowdSec
###############################################################################

CROWDSEC_VERSION=v1.7.8

###############################################################################
# Metabase
###############################################################################

METABASE_VERSION=v0.62.4.3

# External URL (through VPS/WireGuard)
PUBLIC_ADMIN_URL=https://10.100.100.1:9444

#
# Metabase gets its own dedicated port/URL (no subpath --
# see configs/traefik/traefik.yml, entryPoint "metabase").
#
# Requires a SEPARATE port-forward rule on your router/
# WireGuard gateway: <external port> -> 8444 (host),
# same way you already forward 9443 -> 8443 for PUBLIC_ADMIN_URL.
#

METABASE_PUBLIC_URL=https://10.100.100.1:9445

# PostgreSQL

POSTGRES_VERSION=17-alpine

METABASE_DB_NAME=metabase

METABASE_DB_USER=metabase

METABASE_DB_PASSWORD=change_this_password

###############################################################################
# Watchtower
###############################################################################

WATCHTOWER_VERSION=latest

###############################################################################
# Static IP addresses
###############################################################################

IP_TRAEFIK=10.40.0.10
IP_CROWDSEC=10.40.0.11
IP_METABASE=10.40.0.12
IP_POSTGRES_METABASE=10.40.0.13

# Optional second interface (public / DMZ network)
IP_TRAEFIK_PUBLIC=100.40.0.10

###############################################################################
# Persistent data
###############################################################################

DATA_DIR=/docker-data/monitoring-grafana

###############################################################################
# Logging
###############################################################################

LOG_MAX_SIZE=20m
LOG_MAX_FILES=5

###############################################################################
# Grafana
###############################################################################

GRAFANA_VERSION=12.2.0

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_password

GRAFANA_DOMAIN=grafana.serveftp.net

IP_GRAFANA=10.40.0.20

###############################################################################
# Prometheus
###############################################################################

PROMETHEUS_VERSION=v3.5.0

PROMETHEUS_RETENTION=30d

IP_PROMETHEUS=10.40.0.21
