{
  "title": "CrowdSec",
  "uid": "crowdsec-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Parsed log lines / s",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(cs_parser_hits_total[5m])) by (source)",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "New decisions (bans) / s",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(cs_active_decisions[5m]))",
          "legendFormat": "active decisions"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Alerts by scenario",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(cs_alerts[5m])) by (scenario)",
          "legendFormat": "{{scenario}}"
        }
      ]
    }
  ]
}
